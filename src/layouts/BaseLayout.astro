---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
    title: string;
    description?: string;
    image?: string;
    structuredData?: Record<string, unknown> | Record<string, unknown>[];
    noindex?: boolean;
}

const {
    title,
    description = "A portfolio of digital products creating tiny, easy to use tools for better productivity and focus.",
    image = "/img/og-image.png",
    structuredData: pageStructuredData,
    noindex = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://simplebytes.com");
const imageURL = new URL(image, "https://simplebytes.com");

const organizationStructuredData = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Simple Bytes",
    "url": "https://simplebytes.com",
    "logo": "https://simplebytes.com/img/logo.png",
    "description": "A portfolio of digital products creating tiny, easy to use tools for better productivity and focus.",
    "sameAs": [
        "https://github.com/simplebytes-com"
    ]
};

const structuredDataItems = [
    organizationStructuredData,
    ...(Array.isArray(pageStructuredData) ? pageStructuredData : pageStructuredData ? [pageStructuredData] : [])
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="author" content="Simple Bytes">
    <meta name="robots" content={noindex ? "noindex, follow" : "index, follow"}>
    <link rel="canonical" href={canonicalURL}>

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={imageURL}>
    <meta property="og:site_name" content="Simple Bytes">
    <meta property="og:locale" content="en_US">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={imageURL}>

    <!-- Structured Data -->
    {structuredDataItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/img/favicon-96x96.png" sizes="96x96">
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg">
    <link rel="shortcut icon" href="/img/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png">
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)">

    <script is:inline>
        (function() {
            var t = localStorage.getItem('theme');
            if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <!-- Analytics -->
    <script is:inline>
        window.op = window.op || function() {
            var queue = [];
            return new Proxy(function() {
                arguments.length && queue.push([].slice.call(arguments));
            }, {
                get: function(_target, property) {
                    return property === 'q' ? queue : function() {
                        queue.push([property].concat([].slice.call(arguments)));
                    };
                },
                has: function(_target, property) {
                    return property === 'q';
                }
            });
        }();

        window.op('init', {
            apiUrl: 'https://api.op.simplebytes.com',
            clientId: '3d511e20-e7f7-4078-b7a1-8e9774f0494d',
            trackScreenViews: true,
            trackOutgoingLinks: true,
            trackAttributes: true,
        });
    </script>
    <script src="https://op.simplebytes.com/op1.js" defer async is:inline></script>
    <script defer data-domain="simplebytes.com" src="https://analytics.simplebytes.com/js/script.outbound-links.js"></script>
</head>

<body>
    <div class="grid-background"></div>
    <div class="container">
        <Header />
        <main>
            <slot />
        </main>
        <Footer />
    </div>

    <script>
        const toggle = document.querySelector('.theme-toggle') as HTMLButtonElement;
        if (document.documentElement.getAttribute('data-theme') === 'dark') {
            toggle?.setAttribute('aria-checked', 'true');
        }

        toggle?.addEventListener('click', () => {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            if (isDark) {
                document.documentElement.removeAttribute('data-theme');
                toggle.setAttribute('aria-checked', 'false');
                localStorage.setItem('theme', 'light');
            } else {
                document.documentElement.setAttribute('data-theme', 'dark');
                toggle.setAttribute('aria-checked', 'true');
                localStorage.setItem('theme', 'dark');
            }
        });
    </script>
</body>
</html>

<style>
    main {
        animation: fadeIn 0.5s ease-out;
    }
</style>
