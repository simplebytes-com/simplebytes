---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryLabels: Record<string, string> = {
    acquisition: 'Acquisition',
    product: 'Product',
    insights: 'Insights',
};

const categories = [
    { id: 'all', label: 'All', count: posts.length },
    ...Object.entries(categoryLabels).map(([id, label]) => ({
        id,
        label,
        count: posts.filter((post) => post.data.category === id).length,
    })).filter((category) => category.count > 0),
];

function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
}
---

<BaseLayout
    title="Blog - Simple Bytes"
    description="Product notes, acquisition announcements, launch updates, and operating lessons from Simple Bytes."
    structuredData={{
        "@context": "https://schema.org",
        "@type": "Blog",
        "name": "Simple Bytes Blog",
        "url": "https://simplebytes.com/blog",
        "description": "Product notes, acquisition announcements, launch updates, and operating lessons from Simple Bytes."
    }}
>
    <section class="hero">
        <h1>Blog</h1>
        <p class="tagline">Product notes, acquisition announcements, launch updates, and operating lessons from Simple Bytes.</p>
    </section>

    <div class="filters" role="tablist" aria-label="Filter blog posts">
        {categories.map((category) => (
            <button
                type="button"
                class="filter-tab"
                data-filter={category.id}
                aria-pressed={category.id === 'all' ? 'true' : 'false'}
            >
                <span>{category.label}</span>
                <em>{category.count}</em>
            </button>
        ))}
    </div>

    <div class="posts" data-post-list>
        {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-card" data-category={post.data.category}>
                <div class="post-meta">
                    <span class="post-category">{categoryLabels[post.data.category] || post.data.category}</span>
                    <span class="post-date">{formatDate(post.data.date)}</span>
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-description">{post.data.description}</p>
            </a>
        ))}
    </div>

    <script>
        const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter]'));
        const postCards = Array.from(document.querySelectorAll<HTMLElement>('[data-category]'));

        function setFilter(filter: string) {
            filterButtons.forEach((button) => {
                const active = button.dataset.filter === filter;
                button.setAttribute('aria-pressed', active ? 'true' : 'false');
            });

            postCards.forEach((card) => {
                const visible = filter === 'all' || card.dataset.category === filter;
                card.hidden = !visible;
            });
        }

        filterButtons.forEach((button) => {
            button.addEventListener('click', () => {
                const filter = button.dataset.filter || 'all';
                setFilter(filter);
                const url = new URL(window.location.href);
                if (filter === 'all') {
                    url.searchParams.delete('category');
                } else {
                    url.searchParams.set('category', filter);
                }
                window.history.replaceState({}, '', url);
            });
        });

        const initialFilter = new URLSearchParams(window.location.search).get('category') || 'all';
        if (filterButtons.some((button) => button.dataset.filter === initialFilter)) {
            setFilter(initialFilter);
        }
    </script>
</BaseLayout>

<style>
    .hero {
        margin-bottom: 1.75rem;
    }

    h1 {
        font-size: clamp(2rem, 5vw, 2.75rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
    }

    .tagline {
        font-size: 1.125rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    .filters {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 2rem;
    }

    .filter-tab {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.55rem 0.75rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        color: var(--text-secondary);
        cursor: pointer;
        font: inherit;
        font-size: 0.875rem;
        transition: border-color 0.2s var(--transition), color 0.2s var(--transition), background-color 0.2s var(--transition);
    }

    .filter-tab:hover,
    .filter-tab[aria-pressed="true"] {
        color: var(--text-primary);
        border-color: var(--border-hover);
        background: var(--accent-subtle);
    }

    .filter-tab em {
        font-style: normal;
        font-family: 'Geist Mono', monospace;
        font-size: 0.75rem;
        color: var(--text-tertiary);
    }

    .posts {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .post-card {
        display: block;
        padding: 1.5rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        text-decoration: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .post-card[hidden] {
        display: none;
    }

    .post-card:hover {
        border-color: var(--border-hover);
        box-shadow: var(--shadow-sm);
    }

    .post-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .post-category {
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--accent);
        background: var(--accent-subtle);
        padding: 0.2rem 0.5rem;
        border-radius: var(--radius-sm);
    }

    .post-date {
        font-size: 0.8125rem;
        color: var(--text-tertiary);
    }

    .post-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
        line-height: 1.3;
    }

    .post-description {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 1.75rem;
        }

        .tagline {
            font-size: 1rem;
        }

        .post-card {
            padding: 1.25rem;
        }

        .post-meta {
            flex-wrap: wrap;
        }

        .post-title {
            font-size: 1.125rem;
        }
    }
</style>
