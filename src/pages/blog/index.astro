---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryLabels: Record<string, string> = {
    acquisition: 'Acquisition',
    product: 'Product',
    insights: 'Insights',
};

function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    });
}
---

<BaseLayout
    title="Blog - Simple Bytes"
    description="News, product updates, and insights from Simple Bytes."
>
    <a href="/" class="back-link">← Back to home</a>

    <section class="hero">
        <h1>Blog</h1>
        <p class="tagline">News, product updates, and insights from Simple Bytes.</p>
    </section>

    <div class="posts">
        {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-card">
                <div class="post-meta">
                    <span class="post-category">{categoryLabels[post.data.category] || post.data.category}</span>
                    <span class="post-date">{formatDate(post.data.date)}</span>
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-description">{post.data.description}</p>
            </a>
        ))}
    </div>
</BaseLayout>

<style>
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--text-secondary);
        text-decoration: none;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--text-primary);
    }

    .hero {
        margin-bottom: 3rem;
    }

    h1 {
        font-size: clamp(2rem, 5vw, 2.75rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
    }

    .tagline {
        font-size: 1.125rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    .posts {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .post-card {
        display: block;
        padding: 1.5rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        text-decoration: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .post-card:hover {
        border-color: var(--border-hover);
        box-shadow: var(--shadow-sm);
    }

    .post-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .post-category {
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--accent);
        background: var(--accent-subtle);
        padding: 0.2rem 0.5rem;
        border-radius: var(--radius-sm);
    }

    .post-date {
        font-size: 0.8125rem;
        color: var(--text-tertiary);
    }

    .post-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
        line-height: 1.3;
    }

    .post-description {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 1.75rem;
        }

        .tagline {
            font-size: 1rem;
        }

        .post-card {
            padding: 1.25rem;
        }

        .post-title {
            font-size: 1.125rem;
        }
    }
</style>
