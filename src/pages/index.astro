---
import BaseLayout from '../layouts/BaseLayout.astro';

const featuredTools = [
    {
        name: 'QR Code Generator',
        description: 'Create fully customized QR codes for free. No account, no watermark, local-first in your browser, with PNG and SVG export.',
        href: '/tools/qr-code-generator',
        tag: 'Local browser tool',
        cta: 'Create a QR code'
    },
    {
        name: 'DR Tracker',
        description: 'Track Domain Rating changes while you build backlinks and launch new projects.',
        href: '/tools/dr-tracker',
        tag: 'Free SEO tool',
        cta: 'Track DR'
    },
    {
        name: 'DomainDetails',
        description: 'Look up WHOIS, RDAP, DNS, SSL, marketplace listings, and domain intelligence tools.',
        href: '/tools/domain-details',
        tag: 'Domain research',
        cta: 'Research a domain'
    },
    {
        name: 'OG Image Tester',
        description: 'Preview and debug social sharing cards before your links go live on X, LinkedIn, Facebook, Slack, and more.',
        href: '/tools/og-image-tester',
        tag: 'Social preview',
        cta: 'Test a URL'
    }
];

const moreTools = [
    {
        name: 'Launchpage.xyz',
        description: 'Free and open-source landing pages for newly registered domains.',
        href: '/tools/launchpage',
    },
    {
        name: 'Domain Marketplace Search',
        description: 'Check domain listings across multiple marketplaces from the DomainDetails toolkit.',
        href: 'https://www.domaindetails.com/marketplace?ref=simplebytes',
    },
    {
        name: 'DomainDetails Browser Extension',
        description: 'Research domains directly while you browse.',
        href: 'https://www.domaindetails.com/extension?ref=simplebytes',
    }
];
---

<BaseLayout
    title="Simple Bytes - Free Tools That Respect Your Time"
    description="Free tools by Simple Bytes: local-first QR code generator, domain rating tracker, DomainDetails domain research, and OG image tester. No account required."
>
    <section class="hero">
        <p class="section-label">Simple Bytes Tools</p>
        <h1>Free tools that respect your time.</h1>
        <p class="tagline">
            Simple Bytes builds small, useful tools for domains, SEO, launch work, and web publishing. Start with the free tools below - no account required.
        </p>
        <div class="hero-actions">
            <a href="/tools" class="btn btn--primary">Browse all tools</a>
            <a href="/about" class="btn btn--secondary">About Simple Bytes</a>
        </div>
    </section>

    <section class="tools-section" aria-labelledby="featured-tools">
        <div class="section-heading">
            <h2 id="featured-tools">Featured free tools</h2>
            <p>Free browser-based tools for domains, SEO, and web publishing.</p>
        </div>

        <div class="featured-grid">
            {featuredTools.map((tool) => (
                <a class="tool-card tool-card--featured" href={tool.href}>
                    <span class="tool-tag">{tool.tag}</span>
                    <h3>{tool.name}</h3>
                    <p>{tool.description}</p>
                    <span class="tool-cta">{tool.cta} &rarr;</span>
                </a>
            ))}
        </div>
    </section>

    <section class="tools-section" aria-labelledby="more-tools">
        <div class="section-heading">
            <h2 id="more-tools">More from Simple Bytes</h2>
            <p>More utilities from Simple Bytes.</p>
        </div>

        <div class="compact-grid">
            {moreTools.map((tool) => (
                <a class="tool-card" href={tool.href}>
                    <h3>{tool.name}</h3>
                    <p>{tool.description}</p>
                    <span class="tool-cta">Open tool &rarr;</span>
                </a>
            ))}
        </div>
    </section>

    <section class="portfolio-link" aria-labelledby="portfolio-heading">
        <p class="section-label">Portfolio</p>
        <h2 id="portfolio-heading">Products by Simple Bytes</h2>
        <p>Explore the full Simple Bytes portfolio, including DomainDetails, IconBuddy, EasyChef, Migraine Manager, HyperTxt, and more.</p>
        <a href="/about" class="btn btn--secondary">View the portfolio</a>
    </section>
</BaseLayout>

<style>
    .hero {
        margin-bottom: 3.5rem;
        max-width: 720px;
    }

    h1 {
        font-size: clamp(2.25rem, 6vw, 3.5rem);
        font-weight: 600;
        line-height: 1.08;
        color: var(--text-primary);
        margin-bottom: 1rem;
    }

    .tagline {
        font-size: 1.125rem;
        color: var(--text-secondary);
        max-width: 620px;
        line-height: 1.65;
    }

    .hero-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
    }

    .tools-section {
        margin-bottom: 3.5rem;
    }

    .section-heading {
        margin-bottom: 1.25rem;
    }

    .section-heading h2,
    .portfolio-link h2 {
        font-size: 1.35rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.35rem;
    }

    .section-heading p,
    .portfolio-link p {
        color: var(--text-secondary);
        line-height: 1.55;
    }

    .featured-grid,
    .compact-grid {
        display: grid;
        gap: 1rem;
    }

    .featured-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .compact-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .tool-card {
        display: flex;
        flex-direction: column;
        min-height: 100%;
        padding: 1.25rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        text-decoration: none;
        color: inherit;
        box-shadow: var(--shadow-sm);
        transition: border-color 0.2s var(--transition), box-shadow 0.2s var(--transition), transform 0.2s var(--transition);
    }

    .tool-card:hover {
        border-color: var(--border-hover);
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
    }

    .tool-card h3 {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.45rem;
    }

    .tool-card p {
        flex: 1;
        color: var(--text-secondary);
        font-size: 0.9375rem;
        line-height: 1.55;
    }

    .tool-tag {
        width: fit-content;
        font-family: 'Geist Mono', monospace;
        font-size: 0.6875rem;
        color: var(--text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.8rem;
    }

    .tool-cta {
        display: inline-flex;
        margin-top: 1.1rem;
        color: var(--text-primary);
        font-size: 0.875rem;
        font-weight: 500;
    }

    .portfolio-link {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        max-width: 760px;
    }

    .portfolio-link .btn {
        margin-top: 1rem;
    }

    @media (max-width: 820px) {
        .featured-grid,
        .compact-grid {
            grid-template-columns: 1fr;
        }

    }

    @media (max-width: 640px) {
        .hero {
            margin-bottom: 2.5rem;
        }

        h1 {
            font-size: 2rem;
        }

        .tagline {
            font-size: 1rem;
        }
    }
</style>
