---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExternalToolLanding from '../../components/ExternalToolLanding.astro';
---

<BaseLayout
    title="Free DR Tracker - Simple Bytes"
    description="Track Domain Rating changes for free while you build backlinks, submit to directories, and launch new projects."
>
    <ExternalToolLanding
        label="Free SEO Tool"
        name="DR Tracker"
        description="Track Domain Rating changes over time as you build backlinks, submit to directories, and launch new projects."
        href="https://frogdr.com?via=simplebytes"
        cta="Open DR Tracker"
        features={[
            'Useful for watching early backlink campaigns and launch directories.',
            'Simple enough for founders who do not need a full SEO suite.',
            'A natural companion to DR Launcher and Simple Bytes launch tools.',
            'Linked from the tools hub so it can earn a cleaner Google sitelink.'
        ]}
    />
</BaseLayout>
