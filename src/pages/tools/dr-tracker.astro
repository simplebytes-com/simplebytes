---
import BaseLayout from '../../layouts/BaseLayout.astro';

const features = [
    'Save domains you are actively growing.',
    'Collect Domain Rating snapshots over time.',
    'Use the history to understand when backlink and launch work starts to move.',
    'Built by Simple Bytes for our own domain and launch workflows.'
];
---

<BaseLayout
    title="DR Tracker - Domain Rating Tracking by Simple Bytes"
    description="DR Tracker is a Simple Bytes app for saving domains and watching Domain Rating snapshots over time while you build links and launch projects."
>
    <a href="/tools" class="back-link">← Tools</a>

    <section class="tool-hero">
        <p class="section-label">SEO Tool</p>
        <h1>DR Tracker</h1>
        <p class="tagline">
            DR Tracker keeps a lightweight history of Domain Rating changes, so you can see whether backlink work, launch directories, and domain improvements are actually moving.
        </p>
        <div class="hero-actions">
            <a href="/tools/dr-tracker/app" class="btn btn--primary">Launch DR Tracker →</a>
        </div>
    </section>

    <section class="detail-panel">
        <h2>What it does</h2>
        <div class="feature-list">
            {features.map((feature) => (
                <div class="feature-item">
                    <span></span>
                    <p>{feature}</p>
                </div>
            ))}
        </div>
    </section>
</BaseLayout>

<style>
    .back-link { display: inline-flex; color: var(--text-secondary); text-decoration: none; margin-bottom: 2rem; font-size: 0.875rem; }
    .back-link:hover { color: var(--text-primary); }
    .tool-hero { max-width: 760px; margin-bottom: 2.5rem; }
    h1 { font-size: clamp(2.4rem, 5vw, 3.5rem); font-weight: 650; line-height: 1.08; margin-bottom: 1rem; }
    .tagline { color: var(--text-secondary); font-size: 1.125rem; line-height: 1.7; }
    .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.5rem; }
    .detail-panel { padding: 1.5rem; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-lg); }
    .detail-panel h2 { font-size: 1.25rem; margin-bottom: 1rem; }
    .feature-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.9rem; }
    .feature-item { display: flex; gap: 0.7rem; color: var(--text-secondary); line-height: 1.6; }
    .feature-item span { width: 1rem; height: 2px; flex: 0 0 auto; margin-top: 0.75rem; background: var(--border-hover); }
    @media (max-width: 700px) { .feature-list { grid-template-columns: 1fr; } }
</style>
