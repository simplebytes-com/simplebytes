---
import BaseLayout from '../../layouts/BaseLayout.astro';

const features = [
    {
        title: 'Daily DR snapshots',
        description: 'Cloudflare cron refreshes your saved domains once per day with DR snapshots, powered by Ahrefs.'
    },
    {
        title: 'Long-range views',
        description: 'Start with a six-month view, then switch to one year, two years, or all-time history.'
    },
    {
        title: 'Calendar context',
        description: 'See exactly which days were collected and where Domain Rating changed.'
    },
    {
        title: 'Domain-level detail',
        description: 'Open any domain for trend charts, snapshot history, refresh status, and source attribution.'
    }
];
---

<BaseLayout
    title="DR Tracker - Simple Bytes"
    description="Track DR snapshots over time with charts, calendar views, and domain-level history, powered by Ahrefs."
>
    <a href="/" class="back-link">← Back to Simple Bytes</a>

    <section class="hero">
        <div class="hero-copy">
            <p class="section-label">Free tool</p>
            <h1>DR Tracker</h1>
            <p class="tagline">
                Save domains, collect daily DR snapshots, powered by Ahrefs, and see how authority changes over time.
            </p>
            <div class="hero-actions">
                <a href="/tools/dr-tracker/app" class="btn btn--primary">Open DR Tracker →</a>
                <a href="#features" class="btn btn--secondary">View features</a>
            </div>
            <p class="attribution">
                Domain Rating by <a href="https://ahrefs.com/" target="_blank" rel="noopener">Ahrefs</a>.
            </p>
        </div>

        <div class="product-preview" aria-label="DR Tracker dashboard preview">
            <div class="preview-toolbar">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <div class="preview-header">
                <div>
                    <span class="preview-label">simplebytes.com</span>
                    <strong>DR 48</strong>
                </div>
                <div class="preview-tabs">
                    <span>6M</span>
                    <span>1Y</span>
                    <span>All</span>
                </div>
            </div>
            <div class="preview-chart">
                <svg viewBox="0 0 520 220" role="img" aria-label="Example Domain Rating line chart">
                    <line x1="24" y1="32" x2="24" y2="190"></line>
                    <line x1="24" y1="190" x2="496" y2="190"></line>
                    <polyline points="24,164 86,152 148,156 210,126 272,118 334,96 396,88 458,70 496,64"></polyline>
                    <circle cx="496" cy="64" r="6"></circle>
                </svg>
            </div>
            <div class="preview-calendar">
                {Array.from({ length: 52 }).map((_, index) => (
                    <span style={`opacity: ${0.25 + (index % 8) * 0.09}`}></span>
                ))}
            </div>
        </div>
    </section>

    <section id="features" class="features-section">
        <h2 class="section-title">Built for quiet monitoring</h2>
        <p class="section-description">
            DR Tracker is small on purpose: one login, one domain list, one daily snapshot, clear historical views.
        </p>
        <div class="features-grid">
            {features.map((feature) => (
                <div class="feature-item">
                    <h3 class="feature-title">{feature.title}</h3>
                    <p class="feature-description">{feature.description}</p>
                </div>
            ))}
        </div>
    </section>

    <section class="workflow-section">
        <div>
            <p class="section-label">Workflow</p>
            <h2 class="section-title">Add once. Check daily. Review when it matters.</h2>
        </div>
        <ol>
            <li>Sign in with Google.</li>
            <li>Add the domains you want to monitor.</li>
            <li>Cloudflare Workers refresh DR daily and store snapshots in D1.</li>
            <li>Use graphs and calendar views to understand changes over six months or all-time.</li>
        </ol>
    </section>

    <section class="cta-section">
        <div class="cta-content">
            <h2>Start tracking Domain Rating</h2>
            <p>Open the app, sign in with Google, and add your first domain.</p>
            <div class="cta-links">
                <a href="/tools/dr-tracker/app" class="btn btn--primary">Open DR Tracker →</a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: var(--text-secondary);
        text-decoration: none;
        margin-bottom: 2rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--text-primary);
    }

    .hero {
        min-height: 70vh;
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.1fr);
        gap: 3rem;
        align-items: center;
        margin-bottom: 4rem;
    }

    h1 {
        font-size: clamp(3rem, 8vw, 5.5rem);
        line-height: 0.95;
        font-weight: 700;
        letter-spacing: 0;
        margin-bottom: 1rem;
    }

    .tagline {
        font-size: 1.2rem;
        color: var(--text-secondary);
        max-width: 620px;
        line-height: 1.65;
        margin-bottom: 1.5rem;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .attribution {
        color: var(--text-tertiary);
        font-size: 0.875rem;
    }

    .attribution a {
        color: var(--text-secondary);
    }

    .product-preview {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
    }

    .preview-toolbar {
        display: flex;
        gap: 0.4rem;
        padding: 0.9rem 1rem;
        border-bottom: 1px solid var(--border-color);
    }

    .preview-toolbar span {
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 999px;
        background: var(--border-hover);
    }

    .preview-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.25rem;
        align-items: flex-start;
    }

    .preview-label {
        display: block;
        color: var(--text-secondary);
        font-size: 0.875rem;
        margin-bottom: 0.25rem;
    }

    .preview-header strong {
        font-size: 2rem;
        line-height: 1;
    }

    .preview-tabs {
        display: inline-flex;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        padding: 0.2rem;
        gap: 0.15rem;
    }

    .preview-tabs span {
        min-width: 2.5rem;
        text-align: center;
        padding: 0.35rem 0.55rem;
        border-radius: 6px;
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    .preview-tabs span:first-child {
        background: var(--text-primary);
        color: var(--bg-color);
    }

    .preview-chart {
        padding: 0 1.25rem 1rem;
    }

    .preview-chart svg {
        width: 100%;
        display: block;
    }

    .preview-chart line {
        stroke: var(--border-hover);
    }

    .preview-chart polyline {
        fill: none;
        stroke: #2563eb;
        stroke-width: 5;
        stroke-linecap: round;
        stroke-linejoin: round;
    }

    .preview-chart circle {
        fill: var(--card-bg);
        stroke: #2563eb;
        stroke-width: 5;
    }

    .preview-calendar {
        display: grid;
        grid-template-columns: repeat(26, 1fr);
        gap: 0.28rem;
        padding: 1.25rem;
        border-top: 1px solid var(--border-color);
    }

    .preview-calendar span {
        aspect-ratio: 1;
        border-radius: 3px;
        background: #16a34a;
    }

    .features-section {
        margin-bottom: 4rem;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }

    .feature-item {
        padding: 1.25rem 0;
        border-top: 1px solid var(--border-color);
    }

    .feature-title {
        font-size: 1.05rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
    }

    .feature-description {
        color: var(--text-secondary);
        line-height: 1.6;
    }

    .workflow-section {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        gap: 2rem;
        padding: 2rem 0;
        margin-bottom: 4rem;
        border-top: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
    }

    ol {
        color: var(--text-secondary);
        line-height: 1.8;
        padding-left: 1.25rem;
    }

    .cta-section {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-xl);
        padding: 2.5rem;
        margin-bottom: 2rem;
    }

    .cta-content {
        max-width: 620px;
    }

    .cta-content h2 {
        font-size: 1.6rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }

    .cta-content p {
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
    }

    @media (max-width: 860px) {
        .hero,
        .workflow-section {
            grid-template-columns: 1fr;
        }

        .hero {
            min-height: auto;
        }

        .features-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 540px) {
        .product-preview {
            margin-left: -0.5rem;
            margin-right: -0.5rem;
        }

        .preview-header {
            flex-direction: column;
        }

        .preview-calendar {
            grid-template-columns: repeat(13, 1fr);
        }

        .cta-section {
            padding: 1.5rem;
        }
    }
</style>
