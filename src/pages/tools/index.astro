---
import BaseLayout from '../../layouts/BaseLayout.astro';

const localTools = [
    {
        name: 'QR Code Generator',
        description: 'Fully featured, no-account QR code generator with local-first customization and PNG or SVG export.',
        href: '/tools/qr-code-generator',
        tag: 'Local browser tool'
    }
];

const freeTools = [
    {
        name: 'DR Tracker',
        description: 'Track Domain Rating changes while you build backlinks and launch new projects.',
        href: '/tools/dr-tracker',
        tag: 'SEO'
    },
    {
        name: 'DomainDetails',
        description: 'WHOIS, RDAP, DNS, SSL, marketplace search, browser extension, and domain intelligence tools.',
        href: '/tools/domain-details',
        tag: 'Domains'
    },
    {
        name: 'OG Image Tester',
        description: 'Preview and debug Open Graph images before sharing a page on social platforms.',
        href: '/tools/og-image-tester',
        tag: 'Publishing'
    },
    {
        name: 'Launchpage.xyz',
        description: 'Free and open-source landing pages for newly registered domains.',
        href: '/tools/launchpage',
        tag: 'Launch'
    }
];
---

<BaseLayout
    title="Free Tools by Simple Bytes"
    description="Browse free tools from Simple Bytes, including a local-first QR code generator, DR tracker, DomainDetails, OG image tester, and launch page tools."
>
    <section class="hero">
        <p class="section-label">Tools</p>
        <h1>Free tools by Simple Bytes</h1>
        <p class="tagline">
            Focused utilities for domains, SEO, launch work, and web publishing. Free, fast, and built without account walls.
        </p>
    </section>

    <section class="tool-section">
        <div class="section-heading">
            <h2>Local-first tools</h2>
            <p>Run directly in the browser without uploading your work.</p>
        </div>
        <div class="tool-grid">
            {localTools.map((tool) => (
                <a href={tool.href} class="tool-card">
                    <span>{tool.tag}</span>
                    <h3>{tool.name}</h3>
                    <p>{tool.description}</p>
                </a>
            ))}
        </div>
    </section>

    <section class="tool-section">
        <div class="section-heading">
            <h2>More free tools</h2>
            <p>Additional utilities from Simple Bytes.</p>
        </div>
        <div class="tool-grid">
            {freeTools.map((tool) => (
                <a href={tool.href} class="tool-card">
                    <span>{tool.tag}</span>
                    <h3>{tool.name}</h3>
                    <p>{tool.description}</p>
                </a>
            ))}
        </div>
    </section>
</BaseLayout>

<style>
    .hero {
        margin-bottom: 3rem;
        max-width: 680px;
    }

    h1 {
        font-size: clamp(2rem, 5vw, 2.75rem);
        font-weight: 600;
        line-height: 1.15;
        color: var(--text-primary);
        margin-bottom: 1rem;
    }

    .tagline,
    .section-heading p {
        color: var(--text-secondary);
        line-height: 1.65;
    }

    .tool-section {
        margin-bottom: 3rem;
    }

    .section-heading {
        margin-bottom: 1.25rem;
    }

    .section-heading h2 {
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 0.35rem;
    }

    .tool-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .tool-card {
        display: flex;
        flex-direction: column;
        min-height: 100%;
        padding: 1.25rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        text-decoration: none;
        color: inherit;
        box-shadow: var(--shadow-sm);
        transition: border-color 0.2s var(--transition), box-shadow 0.2s var(--transition), transform 0.2s var(--transition);
    }

    .tool-card:hover {
        border-color: var(--border-hover);
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
    }

    .tool-card span {
        width: fit-content;
        font-family: 'Geist Mono', monospace;
        font-size: 0.6875rem;
        color: var(--text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.8rem;
    }

    .tool-card h3 {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 0.45rem;
    }

    .tool-card p {
        color: var(--text-secondary);
        line-height: 1.55;
    }

    @media (max-width: 720px) {
        .tool-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
