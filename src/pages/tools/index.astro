---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
    {
        name: 'QR Code Generator',
        description: 'Create custom QR codes with logo uploads, colors, shapes, PNG export, and SVG export. Runs locally in your browser.',
        href: '/tools/qr-code-generator',
    },
    {
        name: 'DR Tracker',
        description: 'Track Domain Rating snapshots for domains you are growing.',
        href: '/tools/dr-tracker/app',
    },
    {
        name: 'DomainDetails',
        description: 'Research domains with WHOIS, RDAP, DNS, SSL, marketplace, extension, and API tools.',
        href: 'https://www.domaindetails.com?ref=simplebytes',
    },
    {
        name: 'IconBuddy',
        description: 'Find and customize open-source icons across hundreds of icon sets.',
        href: 'https://www.iconbuddy.com?ref=simplebytes',
    },
    {
        name: 'OG Image Tester',
        description: 'Preview social link cards before publishing a page.',
        href: 'https://ogimagepreview.com?ref=simplebytes',
    },
    {
        name: 'LaunchPage.xyz',
        description: 'Add a clean placeholder site to a new domain while the real product is being built.',
        href: 'https://launchpage.xyz?ref=simplebytes',
    },
    {
        name: 'DR Launcher',
        description: 'Directory and backlink launch workflows for early-stage sites.',
        href: 'https://www.drlauncher.com?ref=simplebytes',
    },
];
---

<BaseLayout
    title="Tools - Simple Bytes"
    description="Free tools from Simple Bytes — QR code generator, DR tracker, OG image tester, and LaunchPage."
    structuredData={{
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": "Tools by Simple Bytes",
        "itemListElement": tools.map((tool, index) => ({
            "@type": "ListItem",
            "position": index + 1,
            "name": tool.name,
            "url": tool.href.startsWith('http') ? tool.href : `https://simplebytes.com${tool.href}`
        }))
    }}
>
    <section class="hero">
        <h1>Tools</h1>
        <p class="tagline">Pick a tool and start using it. No sign-up required.</p>
    </section>

    <section class="tool-list" aria-label="Simple Bytes tools">
        {tools.map((tool) => (
            <a class="tool-card" href={tool.href}>
                <h3>{tool.name}</h3>
                <p>{tool.description}</p>
                <span class="tool-cta">Launch &rarr;</span>
            </a>
        ))}
    </section>
</BaseLayout>

<style>
    .hero {
        margin-bottom: 2.5rem;
    }

    h1 {
        font-size: clamp(2rem, 5vw, 2.75rem);
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: -0.03em;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
    }

    .tagline {
        color: var(--text-secondary);
        font-size: 1.1rem;
        line-height: 1.6;
    }

    .tool-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }

    .tool-card {
        display: flex;
        flex-direction: column;
        min-height: 200px;
        padding: 1.25rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        color: inherit;
        text-decoration: none;
        box-shadow: var(--shadow-sm);
        transition: border-color 0.2s var(--transition), transform 0.2s var(--transition), box-shadow 0.2s var(--transition);
    }

    .tool-card:hover {
        border-color: var(--border-hover);
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
    }

    .tool-card h3 {
        margin: 0 0 0.5rem;
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    .tool-card p {
        flex: 1;
        color: var(--text-secondary);
        font-size: 0.9375rem;
        line-height: 1.55;
    }

    .tool-cta {
        margin-top: 1.2rem;
        color: var(--text-primary);
        font-size: 0.9rem;
        font-weight: 500;
    }

    @media (max-width: 640px) {
        .tool-list {
            grid-template-columns: 1fr;
        }

        .tool-card {
            min-height: 0;
        }
    }
</style>
