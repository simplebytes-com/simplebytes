---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Free Custom QR Code Generator - No Account, Local First | Simple Bytes';
const description = 'Create fully customized QR codes for free with no account required. This local-first QR code generator runs in your browser, keeps logo uploads private, and exports PNG or SVG files.';
---

<BaseLayout title={title} description={description}>
    <section class="tool-hero">
        <p class="section-label">Free Tool</p>
        <h1>Custom QR Code Generator</h1>
        <p class="tagline">
            Make fully customized QR codes for free, with no account, no watermark, and no upload step. Everything runs local-first in your browser, including logo previews and PNG or SVG exports.
        </p>
    </section>

    <section class="tool-shell" aria-label="QR code generator">
        <form class="controls" id="qr-controls">
            <div class="panel">
                <div class="panel-heading">
                    <h2>Content</h2>
                    <p>Choose what the QR code should open.</p>
                </div>

                <label class="field">
                    <span>Type</span>
                    <select id="content-type" name="contentType">
                        <option value="url">URL</option>
                        <option value="text">Plain text</option>
                        <option value="email">Email</option>
                        <option value="phone">Phone</option>
                        <option value="sms">SMS</option>
                        <option value="wifi">WiFi</option>
                        <option value="vcard">vCard</option>
                    </select>
                </label>

                <div class="content-panel is-active" data-content-panel="url">
                    <label class="field">
                        <span>Website URL</span>
                        <input id="url-value" type="url" value="https://simplebytes.com" autocomplete="url" />
                    </label>
                </div>

                <div class="content-panel" data-content-panel="text">
                    <label class="field">
                        <span>Text</span>
                        <textarea id="text-value" rows="4">Generated locally with Simple Bytes.</textarea>
                    </label>
                </div>

                <div class="content-panel" data-content-panel="email">
                    <label class="field">
                        <span>Email address</span>
                        <input id="email-address" type="email" placeholder="hello@example.com" />
                    </label>
                    <label class="field">
                        <span>Subject</span>
                        <input id="email-subject" type="text" placeholder="Hello from the QR code" />
                    </label>
                    <label class="field">
                        <span>Message</span>
                        <textarea id="email-body" rows="3" placeholder="Optional email body"></textarea>
                    </label>
                </div>

                <div class="content-panel" data-content-panel="phone">
                    <label class="field">
                        <span>Phone number</span>
                        <input id="phone-number" type="tel" placeholder="+1 555 0100" />
                    </label>
                </div>

                <div class="content-panel" data-content-panel="sms">
                    <label class="field">
                        <span>Phone number</span>
                        <input id="sms-number" type="tel" placeholder="+1 555 0100" />
                    </label>
                    <label class="field">
                        <span>Message</span>
                        <textarea id="sms-message" rows="3" placeholder="Optional text message"></textarea>
                    </label>
                </div>

                <div class="content-panel" data-content-panel="wifi">
                    <label class="field">
                        <span>Network name</span>
                        <input id="wifi-ssid" type="text" placeholder="My WiFi" />
                    </label>
                    <label class="field">
                        <span>Password</span>
                        <input id="wifi-password" type="text" placeholder="Optional password" />
                    </label>
                    <label class="field">
                        <span>Security</span>
                        <select id="wifi-security">
                            <option value="WPA">WPA/WPA2</option>
                            <option value="WEP">WEP</option>
                            <option value="nopass">No password</option>
                        </select>
                    </label>
                    <label class="check-field">
                        <input id="wifi-hidden" type="checkbox" />
                        <span>Hidden network</span>
                    </label>
                </div>

                <div class="content-panel" data-content-panel="vcard">
                    <label class="field">
                        <span>Full name</span>
                        <input id="vcard-name" type="text" placeholder="Alex Morgan" />
                    </label>
                    <label class="field">
                        <span>Company</span>
                        <input id="vcard-company" type="text" placeholder="Simple Bytes" />
                    </label>
                    <label class="field">
                        <span>Phone</span>
                        <input id="vcard-phone" type="tel" placeholder="+1 555 0100" />
                    </label>
                    <label class="field">
                        <span>Email</span>
                        <input id="vcard-email" type="email" placeholder="alex@example.com" />
                    </label>
                    <label class="field">
                        <span>Website</span>
                        <input id="vcard-url" type="url" placeholder="https://example.com" />
                    </label>
                </div>
            </div>

            <div class="panel">
                <div class="panel-heading">
                    <h2>Design</h2>
                    <p>Customize colors, dots, corners, and spacing.</p>
                </div>

                <div class="color-grid">
                    <label class="field color-field">
                        <span>Foreground</span>
                        <input id="foreground-color" type="color" value="#171717" />
                    </label>
                    <label class="field color-field">
                        <span>Background</span>
                        <input id="background-color" type="color" value="#ffffff" />
                    </label>
                    <label class="field color-field">
                        <span>Gradient end</span>
                        <input id="gradient-color" type="color" value="#2563eb" />
                    </label>
                </div>

                <label class="check-field">
                    <input id="use-gradient" type="checkbox" />
                    <span>Use foreground gradient</span>
                </label>

                <label class="check-field">
                    <input id="transparent-bg" type="checkbox" />
                    <span>Transparent background</span>
                </label>

                <div class="control-grid">
                    <label class="field">
                        <span>Dot style</span>
                        <select id="dot-style">
                            <option value="rounded">Rounded</option>
                            <option value="dots">Dots</option>
                            <option value="classy">Classy</option>
                            <option value="classy-rounded">Classy rounded</option>
                            <option value="extra-rounded">Extra rounded</option>
                            <option value="square">Square</option>
                        </select>
                    </label>

                    <label class="field">
                        <span>Corner square</span>
                        <select id="corner-square-style">
                            <option value="extra-rounded">Extra rounded</option>
                            <option value="dot">Dot</option>
                            <option value="square">Square</option>
                        </select>
                    </label>

                    <label class="field">
                        <span>Corner dot</span>
                        <select id="corner-dot-style">
                            <option value="dot">Dot</option>
                            <option value="square">Square</option>
                        </select>
                    </label>

                    <label class="field">
                        <span>Error correction</span>
                        <select id="error-correction">
                            <option value="M">Medium</option>
                            <option value="Q">Quartile</option>
                            <option value="H">High</option>
                            <option value="L">Low</option>
                        </select>
                    </label>
                </div>

                <label class="range-field">
                    <span>Size <output id="size-output">1024px</output></span>
                    <input id="qr-size" type="range" min="256" max="2048" step="128" value="1024" />
                </label>

                <label class="range-field">
                    <span>Margin <output id="margin-output">24px</output></span>
                    <input id="qr-margin" type="range" min="0" max="96" step="4" value="24" />
                </label>
            </div>

            <div class="panel">
                <div class="panel-heading">
                    <h2>Logo</h2>
                    <p>Logo files stay in your browser and are never uploaded.</p>
                </div>

                <label class="field">
                    <span>Logo image</span>
                    <input id="logo-file" type="file" accept="image/png,image/jpeg,image/svg+xml,image/webp" />
                </label>

                <label class="range-field">
                    <span>Logo size <output id="logo-size-output">18%</output></span>
                    <input id="logo-size" type="range" min="8" max="30" step="1" value="18" />
                </label>

                <label class="range-field">
                    <span>Logo padding <output id="logo-margin-output">8px</output></span>
                    <input id="logo-margin" type="range" min="0" max="24" step="2" value="8" />
                </label>

                <button class="btn btn--secondary button-full" id="remove-logo" type="button">Remove logo</button>
            </div>
        </form>

        <aside class="preview-panel" aria-label="QR code preview">
            <div class="preview-card">
                <div id="qr-preview" class="qr-preview" aria-live="polite"></div>
                <p id="qr-warning" class="warning" hidden></p>
                <div class="download-row">
                    <button class="btn btn--primary" id="download-png" type="button">Download PNG</button>
                    <button class="btn btn--secondary" id="download-svg" type="button">Download SVG</button>
                </div>
                <button class="copy-button" id="copy-svg" type="button">Copy SVG</button>
            </div>

            <div class="privacy-note">
                <h2>Private by design</h2>
                <p>
                    QR content, colors, and logo files are processed locally in this page. Simple Bytes does not require an account and does not receive your generated QR code.
                </p>
            </div>
        </aside>
    </section>
</BaseLayout>

<script>
    import QRCodeStyling from 'qr-code-styling';

    const $ = (id: string) => document.getElementById(id);

    const contentType = $('content-type') as HTMLSelectElement;
    const preview = $('qr-preview') as HTMLDivElement;
    const warning = $('qr-warning') as HTMLParagraphElement;
    const sizeInput = $('qr-size') as HTMLInputElement;
    const marginInput = $('qr-margin') as HTMLInputElement;
    const logoSizeInput = $('logo-size') as HTMLInputElement;
    const logoMarginInput = $('logo-margin') as HTMLInputElement;
    const sizeOutput = $('size-output') as HTMLOutputElement;
    const marginOutput = $('margin-output') as HTMLOutputElement;
    const logoSizeOutput = $('logo-size-output') as HTMLOutputElement;
    const logoMarginOutput = $('logo-margin-output') as HTMLOutputElement;

    let logoDataUrl: string | undefined;

    const qrCode = new QRCodeStyling({
        width: 1024,
        height: 1024,
        type: 'svg',
        data: 'https://simplebytes.com',
        qrOptions: {
            errorCorrectionLevel: 'M'
        },
        dotsOptions: {
            color: '#171717',
            type: 'rounded'
        },
        backgroundOptions: {
            color: '#ffffff'
        },
        cornersSquareOptions: {
            type: 'extra-rounded',
            color: '#171717'
        },
        cornersDotOptions: {
            type: 'dot',
            color: '#171717'
        },
        imageOptions: {
            crossOrigin: 'anonymous',
            margin: 8,
            imageSize: 0.18,
            hideBackgroundDots: true
        }
    });

    qrCode.append(preview);

    function inputValue(id: string) {
        return (($(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement)?.value || '').trim();
    }

    function checked(id: string) {
        return Boolean(($(id) as HTMLInputElement)?.checked);
    }

    function encodeMailto(address: string, subject: string, body: string) {
        const params = new URLSearchParams();
        if (subject) params.set('subject', subject);
        if (body) params.set('body', body);
        const query = params.toString();
        return `mailto:${address}${query ? `?${query}` : ''}`;
    }

    function escapeWifi(value: string) {
        return value.replace(/([\\;,:"])/g, '\\$1');
    }

    function buildVCard() {
        const name = inputValue('vcard-name');
        const company = inputValue('vcard-company');
        const phone = inputValue('vcard-phone');
        const email = inputValue('vcard-email');
        const url = inputValue('vcard-url');

        return [
            'BEGIN:VCARD',
            'VERSION:3.0',
            name ? `FN:${name}` : '',
            company ? `ORG:${company}` : '',
            phone ? `TEL:${phone}` : '',
            email ? `EMAIL:${email}` : '',
            url ? `URL:${url}` : '',
            'END:VCARD'
        ].filter(Boolean).join('\n');
    }

    function buildPayload() {
        switch (contentType.value) {
            case 'text':
                return inputValue('text-value') || 'Generated locally with Simple Bytes.';
            case 'email':
                return encodeMailto(inputValue('email-address') || 'hello@example.com', inputValue('email-subject'), inputValue('email-body'));
            case 'phone':
                return `tel:${inputValue('phone-number') || '+15550100'}`;
            case 'sms':
                return `SMSTO:${inputValue('sms-number') || '+15550100'}:${inputValue('sms-message')}`;
            case 'wifi': {
                const security = inputValue('wifi-security');
                const ssid = escapeWifi(inputValue('wifi-ssid') || 'My WiFi');
                const password = escapeWifi(inputValue('wifi-password'));
                const hidden = checked('wifi-hidden') ? 'true' : 'false';
                return `WIFI:T:${security};S:${ssid};P:${password};H:${hidden};;`;
            }
            case 'vcard':
                return buildVCard();
            case 'url':
            default:
                return inputValue('url-value') || 'https://simplebytes.com';
        }
    }

    function updatePanels() {
        document.querySelectorAll<HTMLElement>('[data-content-panel]').forEach((panel) => {
            panel.classList.toggle('is-active', panel.dataset.contentPanel === contentType.value);
        });
    }

    function updateLabels() {
        sizeOutput.value = `${sizeInput.value}px`;
        marginOutput.value = `${marginInput.value}px`;
        logoSizeOutput.value = `${logoSizeInput.value}%`;
        logoMarginOutput.value = `${logoMarginInput.value}px`;
    }

    function updateWarning() {
        const hasLogo = Boolean(logoDataUrl);
        const logoSize = Number(logoSizeInput.value);
        if (hasLogo && logoSize > 24 && inputValue('error-correction') !== 'H') {
            warning.textContent = 'Large logos scan better with high error correction.';
            warning.hidden = false;
            return;
        }

        warning.hidden = true;
        warning.textContent = '';
    }

    function updateQRCode() {
        updatePanels();
        updateLabels();
        updateWarning();

        const foreground = inputValue('foreground-color') || '#171717';
        const gradient = inputValue('gradient-color') || '#2563eb';
        const transparent = checked('transparent-bg');
        const size = Number(sizeInput.value);
        const margin = Number(marginInput.value);
        const useGradient = checked('use-gradient');

        qrCode.update({
            width: size,
            height: size,
            data: buildPayload(),
            image: logoDataUrl,
            margin,
            qrOptions: {
                errorCorrectionLevel: inputValue('error-correction') || 'M'
            },
            dotsOptions: {
                type: inputValue('dot-style') || 'rounded',
                color: foreground,
                gradient: useGradient
                    ? {
                        type: 'linear',
                        rotation: 0,
                        colorStops: [
                            { offset: 0, color: foreground },
                            { offset: 1, color: gradient }
                        ]
                    }
                    : undefined
            },
            backgroundOptions: {
                color: transparent ? 'transparent' : inputValue('background-color') || '#ffffff'
            },
            cornersSquareOptions: {
                type: inputValue('corner-square-style') || 'extra-rounded',
                color: foreground
            },
            cornersDotOptions: {
                type: inputValue('corner-dot-style') || 'dot',
                color: foreground
            },
            imageOptions: {
                crossOrigin: 'anonymous',
                margin: Number(logoMarginInput.value),
                imageSize: Number(logoSizeInput.value) / 100,
                hideBackgroundDots: true
            }
        });
    }

    async function download(extension: 'png' | 'svg') {
        const raw = await qrCode.getRawData(extension);
        if (!raw) return;

        const blob = raw instanceof Blob ? raw : new Blob([raw]);
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = `simplebytes-qr-code.${extension}`;
        document.body.appendChild(link);
        link.click();
        link.remove();
        window.setTimeout(() => URL.revokeObjectURL(url), 30000);
    }

    async function copySvg() {
        const raw = await qrCode.getRawData('svg');
        if (!raw) return;
        const svg = await raw.text();
        await navigator.clipboard.writeText(svg);
        const button = $('copy-svg') as HTMLButtonElement;
        const previous = button.textContent;
        button.textContent = 'SVG copied';
        window.setTimeout(() => {
            button.textContent = previous;
        }, 1400);
    }

    document.querySelectorAll('input, select, textarea').forEach((element) => {
        element.addEventListener('input', updateQRCode);
        element.addEventListener('change', updateQRCode);
    });

    $('logo-file')?.addEventListener('change', (event) => {
        const file = (event.currentTarget as HTMLInputElement).files?.[0];
        if (!file) return;

        const reader = new FileReader();
        reader.addEventListener('load', () => {
            logoDataUrl = String(reader.result);
            updateQRCode();
        });
        reader.readAsDataURL(file);
    });

    $('remove-logo')?.addEventListener('click', () => {
        logoDataUrl = undefined;
        ($('logo-file') as HTMLInputElement).value = '';
        updateQRCode();
    });

    $('download-png')?.addEventListener('click', () => download('png'));
    $('download-svg')?.addEventListener('click', () => download('svg'));
    $('copy-svg')?.addEventListener('click', copySvg);

    updateQRCode();
</script>

<style>
    .tool-hero {
        max-width: 740px;
        margin-bottom: 2rem;
    }

    h1 {
        font-size: clamp(2rem, 5vw, 2.75rem);
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: -0.03em;
        color: var(--text-primary);
        margin-bottom: 1rem;
    }

    .tagline {
        font-size: 1.0625rem;
        color: var(--text-secondary);
        line-height: 1.7;
    }

    .tool-shell {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
        gap: 1.25rem;
        align-items: start;
    }

    .controls,
    .preview-panel {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .panel,
    .preview-card,
    .privacy-note {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        padding: 1.25rem;
    }

    .panel-heading {
        margin-bottom: 1rem;
    }

    h2 {
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text-primary);
        margin-bottom: 0.25rem;
    }

    .panel-heading p,
    .privacy-note p {
        color: var(--text-secondary);
        font-size: 0.875rem;
        line-height: 1.5;
    }

    .field,
    .range-field {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin-bottom: 0.875rem;
    }

    .field span,
    .range-field span,
    .check-field span {
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--text-secondary);
    }

    input,
    select,
    textarea {
        width: 100%;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        background: var(--bg-secondary);
        color: var(--text-primary);
        font: inherit;
        font-size: 0.9375rem;
        padding: 0.75rem 0.85rem;
        transition: border-color 0.2s var(--transition), box-shadow 0.2s var(--transition);
    }

    textarea {
        resize: vertical;
    }

    input:focus,
    select:focus,
    textarea:focus {
        outline: none;
        border-color: var(--border-hover);
        box-shadow: 0 0 0 3px var(--accent-subtle);
    }

    input[type="color"] {
        min-height: 2.75rem;
        padding: 0.25rem;
        cursor: pointer;
    }

    input[type="range"] {
        padding: 0;
        accent-color: var(--accent);
    }

    .content-panel {
        display: none;
    }

    .content-panel.is-active {
        display: block;
    }

    .color-grid,
    .control-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .color-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .check-field {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        margin-bottom: 0.875rem;
    }

    .check-field input {
        width: 1rem;
        height: 1rem;
        flex: 0 0 auto;
    }

    .range-field span {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
    }

    output {
        color: var(--text-tertiary);
        font-family: 'Geist Mono', monospace;
        font-size: 0.75rem;
    }

    .button-full {
        justify-content: center;
        width: 100%;
    }

    .preview-panel {
        position: sticky;
        top: 1rem;
    }

    .preview-card {
        text-align: center;
    }

    .qr-preview {
        display: grid;
        place-items: center;
        min-height: 320px;
        padding: 1rem;
        background:
            linear-gradient(45deg, var(--accent-subtle) 25%, transparent 25%),
            linear-gradient(-45deg, var(--accent-subtle) 25%, transparent 25%),
            linear-gradient(45deg, transparent 75%, var(--accent-subtle) 75%),
            linear-gradient(-45deg, transparent 75%, var(--accent-subtle) 75%);
        background-size: 24px 24px;
        background-position: 0 0, 0 12px, 12px -12px, -12px 0;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    .qr-preview :global(svg),
    .qr-preview :global(canvas) {
        width: min(100%, 320px) !important;
        height: auto !important;
        display: block;
        border-radius: var(--radius-sm);
    }

    .download-row {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .copy-button {
        width: 100%;
        margin-top: 0.75rem;
        border: 0;
        background: transparent;
        color: var(--text-secondary);
        font: inherit;
        font-size: 0.875rem;
        cursor: pointer;
        padding: 0.5rem;
    }

    .copy-button:hover {
        color: var(--text-primary);
    }

    .warning {
        margin-top: 0.75rem;
        color: #b45309;
        background: rgba(245, 158, 11, 0.12);
        border-radius: var(--radius-sm);
        padding: 0.75rem;
        font-size: 0.8125rem;
        line-height: 1.4;
    }

    :global([data-theme="dark"]) .warning {
        color: #fbbf24;
    }

    @media (max-width: 900px) {
        .tool-shell {
            grid-template-columns: 1fr;
        }

        .preview-panel {
            position: static;
        }
    }

    @media (max-width: 640px) {
        .tool-hero {
            margin-bottom: 1.5rem;
        }

        .color-grid,
        .control-grid,
        .download-row {
            grid-template-columns: 1fr;
        }

        .panel,
        .preview-card,
        .privacy-note {
            padding: 1rem;
        }

        .qr-preview {
            min-height: 260px;
        }
    }
</style>
